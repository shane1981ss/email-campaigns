<div class="page-header">
  <div>
    <a href="/customer-segments" class="breadcrumb-link">&larr; Customer Segments</a>
    <h1><%= segment.name %></h1>
    <% if (segment.description) { %>
      <p class="page-subtitle"><%= segment.description %></p>
    <% } %>
  </div>
</div>

<div id="toast-container"></div>

<script>
  function showToast(message, type) {
    type = type || 'success';
    var container = document.getElementById('toast-container');
    var toast = document.createElement('div');
    toast.className = 'toast toast-' + type;
    toast.innerHTML = '<span>' + message + '</span><button class="toast-dismiss" onclick="dismissToast(this)">&times;</button>';
    container.appendChild(toast);
    setTimeout(function() { dismissToast(toast.querySelector('.toast-dismiss')); }, 4000);
  }
  function dismissToast(btn) {
    var toast = btn.closest('.toast');
    if (!toast) return;
    toast.style.animation = 'toastOut 0.2s ease forwards';
    setTimeout(function() { toast.remove(); }, 200);
  }
  document.addEventListener('DOMContentLoaded', function() {
    var tc = document.getElementById('toast-container');
    if (tc) document.body.appendChild(tc);
    <% if (messages.success && messages.success.length) { %>
      showToast('<%= messages.success.toString().replace(/'/g, "\\'") %>', 'success');
    <% } %>
  });
</script>

<!-- ── Entry Events ─────────────────────────────────────── -->
<div class="section-header">
  <h2 class="section-title">Entry Events</h2>
  <button class="btn btn-primary btn-sm" onclick="openModal('newEntryModal')">+ Add Entry Event</button>
</div>
<div class="card" style="margin-bottom:1.5rem;">
  <table>
    <thead>
      <tr>
        <th class="col-id">#</th>
        <th>Name</th>
        <th>Description</th>
        <th class="col-actions">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (segment.entryEvents.length === 0) { %>
        <tr>
          <td colspan="4" class="empty-row">No entry events. <a href="#" onclick="openModal('newEntryModal');return false;">Add one</a>.</td>
        </tr>
      <% } else { %>
        <% segment.entryEvents.forEach(function(ev) { %>
          <% var entryEvDesc = (allEvents.find(function(e){ return e.name === ev.name; }) || {}).description || ''; %>
          <tr>
            <td class="col-id"><%= ev.id %></td>
            <td><%= ev.name %></td>
            <td><%= entryEvDesc %></td>
            <td class="col-actions">
              <form action="/customer-segments/<%= segment.id %>/entry-events/<%= ev.id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Remove this entry event?')">Remove</button>
              </form>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

