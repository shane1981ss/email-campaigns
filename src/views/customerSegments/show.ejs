<!-- ── Email Series ─────────────────────────────────────── -->
<div class="section-header">
  <h2 class="section-title">Email Series</h2>
  <button class="btn btn-primary btn-sm" onclick="openModal('assignSeriesModal')">+ Assign Email Series</button>
</div>
<div class="card" style="margin-bottom:1.5rem;">
  <table>
    <thead>
      <tr>
        <th class="col-id">#</th>
        <th>Name</th>
        <th>Description</th>
        <th class="col-actions">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (segment.emailSeries.length === 0) { %>
        <tr>
          <td colspan="4" class="empty-row">No email series assigned. <a href="#" onclick="openModal('assignSeriesModal');return false;">Assign one</a>.</td>
        </tr>
      <% } else { %>
        <% segment.emailSeries.forEach(function(series) { %>
          <tr>
            <td class="col-id"><%= series.id %></td>
            <td><a href="/email-series/<%= series.id %>"><%= series.name %></a></td>
            <td><%= series.description %></td>
            <td class="col-actions">
              <form action="/customer-segments/<%= segment.id %>/email-series/<%= series.id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Unassign this email series?')">Unassign</button>
              </form>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<!-- ── Queries ───────────────────────────────────────────── -->
<div class="section-header">
  <h2 class="section-title">Queries</h2>
  <button class="btn btn-primary btn-sm" onclick="openModal('newQueryModal')">+ Add Query</button>
</div>
<div class="card" style="margin-bottom:1.5rem;">
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Query</th>
        <th class="col-actions">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (segment.query.length === 0) { %>
        <tr>
          <td colspan="3" class="empty-row">No queries. <a href="#" onclick="openModal('newQueryModal');return false;">Add one</a>.</td>
        </tr>
      <% } else { %>
        <% segment.query.forEach(function(q) { %>
          <tr>
            <td><%= q.name %></td>
            <td style="white-space:pre-wrap;word-break:break-word;"><%= q.query %></td>
            <td class="col-actions">
              <button class="btn btn-sm btn-secondary" onclick="openEditQueryModal(<%= q.id %>, <%= JSON.stringify(q.name) %>, <%= JSON.stringify(q.query) %>)">Edit</button>
              <form action="/customer-segments/<%= segment.id %>/queries/<%= q.id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this query?')">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<!-- New Query Modal -->
<div class="modal-backdrop" id="newQueryModal" onclick="closeModal('newQueryModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h2>Add Query</h2>
      <button class="modal-close" onclick="closeModal('newQueryModal')">&times;</button>
    </div>
    <div class="modal-body">
      <div id="newQueryErrors" class="flash flash-error" style="display:none;"></div>
      <form id="newQueryForm" onsubmit="submitNewQuery(event)">
        <div class="form-group">
          <label for="newQueryName">Name</label>
          <input type="text" id="newQueryName" name="name">
        </div>
        <div class="form-group">
          <label for="newQueryText">Query</label>
          <textarea id="newQueryText" name="query" rows="6" style="width:100%;resize:vertical;"></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Add Query</button>
          <button type="button" class="btn btn-ghost" onclick="closeModal('newQueryModal')">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Query Modal -->
<div class="modal-backdrop" id="editQueryModal" onclick="closeModal('editQueryModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h2>Edit Query</h2>
      <button class="modal-close" onclick="closeModal('editQueryModal')">&times;</button>
    </div>
    <div class="modal-body">
      <div id="editQueryErrors" class="flash flash-error" style="display:none;"></div>
      <form id="editQueryForm" onsubmit="submitEditQuery(event)">
        <input type="hidden" id="editQueryId" value="">
        <div class="form-group">
          <label for="editQueryName">Name</label>
          <input type="text" id="editQueryName" name="name">
        </div>
        <div class="form-group">
          <label for="editQueryText">Query</label>
          <textarea id="editQueryText" name="query" rows="6" style="width:100%;resize:vertical;"></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Save Changes</button>
          <button type="button" class="btn btn-ghost" onclick="closeModal('editQueryModal')">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- New Entry Event Modal -->
<div class="modal-backdrop" id="newEntryModal" onclick="closeModal('newEntryModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h2>Add Entry Event</h2>
      <button class="modal-close" onclick="closeModal('newEntryModal')">&times;</button>
    </div>
    <div class="modal-body">
      <div id="entryErrors" class="flash flash-error" style="display:none;"></div>
      <form id="entryForm" onsubmit="submitEntryEvent(event)">
        <div class="form-group">
          <label for="entryEventSelect">Event</label>
          <select id="entryEventSelect" name="eventId">
            <option value="">— Select an event —</option>
            <% allEvents.forEach(function(ev) { %>
              <% var alreadyEntry = segment.entryEvents.some(function(e) { return e.name === ev.name; }); %>
              <% if (!alreadyEntry) { %>
                <option value="<%= ev.id %>"><%= ev.name %></option>
              <% } %>
            <% }) %>
          </select>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Add Entry Event</button>
          <button type="button" class="btn btn-ghost" onclick="closeModal('newEntryModal')">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

