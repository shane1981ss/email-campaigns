<!-- Assign Email Series Modal -->
<div class="modal-backdrop" id="assignSeriesModal" onclick="closeModal('assignSeriesModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h2>Assign Email Series</h2>
      <button class="modal-close" onclick="closeModal('assignSeriesModal')">&times;</button>
    </div>
    <div class="modal-body">
      <div id="seriesErrors" class="flash flash-error" style="display:none;"></div>
      <form id="seriesForm" onsubmit="submitAssignSeries(event)">
        <div class="form-group">
          <label for="seriesSelect">Email Series</label>
          <select id="seriesSelect" name="emailSeriesId">
            <option value="">— Select an email series —</option>
            <% allEmailSeries.forEach(function(s) { %>
              <% var alreadyAssigned = segment.emailSeries.some(function(es) { return es.id === s.id; }); %>
              <% if (!alreadyAssigned) { %>
                <option value="<%= s.id %>"><%= s.name %></option>
              <% } %>
            <% }) %>
          </select>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Assign</button>
          <button type="button" class="btn btn-ghost" onclick="closeModal('assignSeriesModal')">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  var segmentId = <%= segment.id %>;

  function openModal(id) {
    document.getElementById(id).classList.add('active');
    var sel = document.querySelector('#' + id + ' select');
    if (sel) sel.value = '';
    var errBox = document.querySelector('#' + id + ' .flash-error');
    if (errBox) errBox.style.display = 'none';
  }
  function closeModal(id) {
    document.getElementById(id).classList.remove('active');
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      ['newEntryModal','newExitModal','assignSeriesModal','newQueryModal','editQueryModal'].forEach(closeModal);
    }
  });

  async function submitEntryEvent(e) {
    e.preventDefault();
    const eventId = document.getElementById('entryEventSelect').value;
    const errBox = document.getElementById('entryErrors');
    const res = await fetch('/customer-segments/' + segmentId + '/entry-events', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ eventId })
    });
    if (res.ok) {
      closeModal('newEntryModal');
      showToast('Entry event added.', 'success');
      setTimeout(function() { window.location.reload(); }, 600);
    } else {
      const data = await res.json();
      errBox.textContent = data.errors.join(' ');
      errBox.style.display = 'block';
    }
  }

  async function submitExitEvent(e) {
    e.preventDefault();
    const eventId = document.getElementById('exitEventSelect').value;
    const errBox = document.getElementById('exitErrors');
    const res = await fetch('/customer-segments/' + segmentId + '/exit-events', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ eventId })
    });
    if (res.ok) {
      closeModal('newExitModal');
      showToast('Exit event added.', 'success');
      setTimeout(function() { window.location.reload(); }, 600);
    } else {
      const data = await res.json();
      errBox.textContent = data.errors.join(' ');
      errBox.style.display = 'block';
    }
  }

  function openEditQueryModal(id, name, text) {
    document.getElementById('editQueryId').value = id;
    document.getElementById('editQueryName').value = name;
    document.getElementById('editQueryText').value = text;
    var errBox = document.getElementById('editQueryErrors');
    if (errBox) errBox.style.display = 'none';
    document.getElementById('editQueryModal').classList.add('active');
  }

  async function submitNewQuery(e) {
    e.preventDefault();
    const name = document.getElementById('newQueryName').value;
    const query = document.getElementById('newQueryText').value;
    const errBox = document.getElementById('newQueryErrors');
    const res = await fetch('/customer-segments/' + segmentId + '/queries', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ name, query })
    });
    if (res.ok) {
      closeModal('newQueryModal');
      showToast('Query added.', 'success');
      setTimeout(function() { window.location.reload(); }, 600);
    } else {
      const data = await res.json();
      errBox.textContent = data.errors.join(' ');
      errBox.style.display = 'block';
    }
  }

  async function submitEditQuery(e) {
    e.preventDefault();
    const queryId = document.getElementById('editQueryId').value;
    const name = document.getElementById('editQueryName').value;
    const query = document.getElementById('editQueryText').value;
    const errBox = document.getElementById('editQueryErrors');
    const res = await fetch('/customer-segments/' + segmentId + '/queries/' + queryId, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ name, query })
    });
    if (res.ok) {
      closeModal('editQueryModal');
      showToast('Query updated.', 'success');
      setTimeout(function() { window.location.reload(); }, 600);
    } else {
      const data = await res.json();
      errBox.textContent = data.errors.join(' ');
      errBox.style.display = 'block';
    }
  }

  async function submitAssignSeries(e) {
    e.preventDefault();
    const emailSeriesId = document.getElementById('seriesSelect').value;
    const errBox = document.getElementById('seriesErrors');
    const res = await fetch('/customer-segments/' + segmentId + '/email-series', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ emailSeriesId })
    });
    if (res.ok) {
      closeModal('assignSeriesModal');
      showToast('Email series assigned.', 'success');
      setTimeout(function() { window.location.reload(); }, 600);
    } else {
      const data = await res.json();
      errBox.textContent = data.errors.join(' ');
      errBox.style.display = 'block';
    }
  }
</script>
