<div class="page-header">
  <h1>Email Series</h1>
  <button class="btn btn-primary" onclick="openNewModal()">+ New Email Series</button>
</div>
<div class="card">
  <table class="table-auto-layout">
    <thead>
      <tr>
        <th class="col-drag"></th>
        <th>Name</th>
        <th class="col-fluid">Description</th>
        <th>Customer Segment</th>
        <th class="col-actions">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (emailSeries.length === 0) { %>
        <tr>
          <td colspan="5" class="empty-row">No email series found. <a href="#" onclick="openNewModal();return false;">Create one</a>.</td>
        </tr>
      <% } else { %>
        <% emailSeries.forEach(function(series) { %>
          <tr data-id="<%= series.id %>">
            <td class="col-drag drag-handle">&#9776;</td>
            <td><a href="/email-series/<%= series.id %>"><%= series.name %></a></td>
            <td><%= series.description %></td>
            <td><%= series.customerSegment ? series.customerSegment.name : '—' %></td>
            <td class="col-actions">
              <button class="btn btn-sm btn-secondary"
                data-id="<%= series.id %>"
                data-name="<%= encodeURIComponent(series.name || '') %>"
                data-description="<%= encodeURIComponent(series.description || '') %>"
                onclick="openEditModal(this)">Edit</button>
              <form action="/email-series/<%= series.id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this email series?')">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<div id="toast-container"></div>

<script>
  function showToast(message, type) {
    type = type || 'success';
    var container = document.getElementById('toast-container');
    var toast = document.createElement('div');
    toast.className = 'toast toast-' + type;
    toast.innerHTML = '<span>' + message + '</span><button class="toast-dismiss" onclick="dismissToast(this)">&times;</button>';
    container.appendChild(toast);
    setTimeout(function() { dismissToast(toast.querySelector('.toast-dismiss')); }, 4000);
  }
  function dismissToast(btn) {
    var toast = btn.closest('.toast');
    if (!toast) return;
    toast.style.animation = 'toastOut 0.2s ease forwards';
    setTimeout(function() { toast.remove(); }, 200);
  }
  document.addEventListener('DOMContentLoaded', function() {
    var tbody = document.querySelector('table tbody');
    if (tbody && typeof Sortable !== 'undefined') {
      Sortable.create(tbody, {
        handle: '.drag-handle',
        animation: 150,
        onEnd: function() {
          var ids = Array.from(tbody.querySelectorAll('tr[data-id]')).map(function(r) { return r.dataset.id; });
          fetch('/email-series/reorder', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ ids: ids })
          });
        }
      });
    }
  });
  document.addEventListener('DOMContentLoaded', function() {
    ['newModal','editModal','toast-container'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) document.body.appendChild(el);
    });
    <% if (messages.success && messages.success.length) { %>
      showToast('<%= messages.success.toString().replace(/'/g, "\\'") %>', 'success');
    <% } %>
  });
</script>

<!-- New Email Series Modal -->
<div class="modal-backdrop" id="newModal" onclick="closeModal('newModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h2>New Email Series</h2>
      <button class="modal-close" onclick="closeModal('newModal')">&times;</button>
    </div>
    <div class="modal-body">
      <div id="newErrors" class="flash flash-error" style="display:none;"></div>
      <form id="newForm" onsubmit="submitNew(event)">
        <div class="form-group">
          <label for="newName">Name</label>
          <input type="text" id="newName" name="name" placeholder="Email series name" autocomplete="off">
        </div>
        <div class="form-group">
          <label for="newDescription">Description</label>
          <textarea id="newDescription" name="description" rows="3" placeholder="Optional description"></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Create Email Series</button>
          <button type="button" class="btn btn-ghost" onclick="closeModal('newModal')">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Email Series Modal -->
<div class="modal-backdrop" id="editModal" onclick="closeModal('editModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h2>Edit Email Series</h2>
      <button class="modal-close" onclick="closeModal('editModal')">&times;</button>
    </div>
    <div class="modal-body">
      <div id="editErrors" class="flash flash-error" style="display:none;"></div>
      <form id="editForm" onsubmit="submitEdit(event)">
        <input type="hidden" id="editId">
        <div class="form-group">
          <label for="editName">Name</label>
          <input type="text" id="editName" name="name" placeholder="Email series name" autocomplete="off">
        </div>
        <div class="form-group">
          <label for="editDescription">Description</label>
          <textarea id="editDescription" name="description" rows="3" placeholder="Optional description"></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Save Changes</button>
          <button type="button" class="btn btn-ghost" onclick="closeModal('editModal')">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function openNewModal() {
    document.getElementById('newName').value = '';
    document.getElementById('newDescription').value = '';
    document.getElementById('newErrors').style.display = 'none';
    document.getElementById('newModal').classList.add('active');
    document.getElementById('newName').focus();
  }
  function openEditModal(btn) {
    const id = btn.dataset.id;
    const name = decodeURIComponent(btn.dataset.name);
    const description = decodeURIComponent(btn.dataset.description);
    document.getElementById('editId').value = id;
    document.getElementById('editName').value = name;
    document.getElementById('editDescription').value = description;
    document.getElementById('editErrors').style.display = 'none';
    document.getElementById('editModal').classList.add('active');
    document.getElementById('editName').focus();
  }
  function closeModal(id) {
    document.getElementById(id).classList.remove('active');
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeModal('newModal');
      closeModal('editModal');
    }
  });
  async function submitNew(e) {
    e.preventDefault();
    const name = document.getElementById('newName').value;
    const description = document.getElementById('newDescription').value;
    const errBox = document.getElementById('newErrors');
    const res = await fetch('/email-series', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ name, description })
    });
    if (res.ok) {
      closeModal('newModal');
      showToast('Email series created successfully.', 'success');
      setTimeout(function() { window.location.reload(); }, 600);
    } else {
      const data = await res.json();
      errBox.textContent = data.errors.join(' ');
      errBox.style.display = 'block';
    }
  }
  async function submitEdit(e) {
    e.preventDefault();
    const id = document.getElementById('editId').value;
    const name = document.getElementById('editName').value;
    const description = document.getElementById('editDescription').value;
    const errBox = document.getElementById('editErrors');
    const res = await fetch('/email-series/' + id + '?_method=PUT', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ name, description })
    });
    if (res.ok) {
      closeModal('editModal');
      showToast('Email series updated successfully.', 'success');
      setTimeout(function() { window.location.reload(); }, 600);
    } else {
      const data = await res.json();
      errBox.textContent = data.errors.join(' ');
      errBox.style.display = 'block';
    }
  }
</script>
