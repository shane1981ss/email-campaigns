# App
NODE_ENV=production
PORT=3000
TZ=UTC

# MySQL
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=email_campaigns
MYSQL_USER=email_campaigns_user
MYSQL_PASSWORD=your_db_password_here

# App database connection
DATABASE_URL=mysql://email_campaigns_user:your_db_password_here@mysql:3306/email_campaigns

# Redis
REDIS_URL=redis://redis:6379

# phpMyAdmin
PMA_HOST=mysql
PMA_PORT=3306
UPLOAD_LIMIT=128M